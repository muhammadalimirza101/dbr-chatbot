# DBR WhatsApp AI Chatbot — environment template
# Copy to `.env` and fill with real values. NEVER commit `.env`.

# PostgreSQL (existing local instance). Format:
# postgresql+asyncpg://<user>:<password>@localhost:5432/<dbname>
DATABASE_URL=postgresql+asyncpg://dbr_app:CHANGE_ME@localhost:5432/dbr_chatbot

# OpenAI
OPENAI_API_KEY=sk-CHANGE_ME

# Auth — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING

# Exact origin of the React dashboard (no trailing slash)
DASHBOARD_ORIGIN=http://localhost:5173

# Baileys session directory — MUST be OUTSIDE this repository
WHATSAPP_SESSION_DIR=C:/Users/CHANGE_ME/dbr-wa-session

# Shared secret between connector and backend — generate like JWT_SECRET
CONNECTOR_SHARED_SECRET=CHANGE_ME_LONG_RANDOM_STRING
